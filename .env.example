AUTH_API_PORT=8787
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# auto | smtp | resend
OTP_EMAIL_PROVIDER=auto

# SMTP configuration (use if provider is auto/smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# Resend configuration (use if provider is auto/resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Only for local testing when no provider is configured.
ALLOW_CONSOLE_OTP=false
